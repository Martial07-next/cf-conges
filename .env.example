# Base de donnees PostgreSQL (ex: fournie par Supabase -> Settings > Database > Connection string)
DATABASE_URL="postgresql://user:password@host:5432/cf_conges?schema=public"

# Genere avec: openssl rand -base64 32
NEXTAUTH_SECRET="change-moi"
NEXTAUTH_URL="http://localhost:3000"

# Optionnel - emails transactionnels (validation/refus). Sans cette cle,
# les notifications restent visibles dans l'app mais aucun email n'est envoye.
RESEND_API_KEY=""
EMAIL_FROM="CF Reseaux Conges <conges@cf-reseaux.fr>"
